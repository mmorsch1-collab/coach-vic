{
  "name": "bridge-api",
  "version": "1.0.0",
  "description": "OAuth token management and API bridge service for WHOOP and Google APIs",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "security-check": "tsx scripts/security-check.ts",
    "setup": "tsx scripts/setup-oauth.ts"
  },
  "keywords": [
    "oauth",
    "whoop",
    "google-api",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "compression": "^1.8.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "tsdav": "^2.1.8",
    "zod": "^3.22.4"
  }
}
