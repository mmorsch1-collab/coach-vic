{
  "name": "coach-vic",
  "version": "1.0.0",
  "description": "Open source AI health coach that monitors WHOOP, Withings, and Strava for proactive coaching",
  "main": "index.js",
  "scripts": {
    "validate": "node scripts/validate-setup.js",
